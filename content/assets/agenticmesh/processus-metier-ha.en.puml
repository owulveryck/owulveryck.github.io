@startuml
!theme plain
skinparam backgroundColor #FFFFFF
skinparam defaultFontName Helvetica
skinparam defaultFontSize 11

left to right direction
hide empty description

skinparam RoundCorner 14
skinparam state {
  FontSize 11
}

title **BUSINESS PROCESS** — complex order processing

state "**H**\nRequest" as h1 #E7E9EE
state "**A** //Logistics//\nRescheduling" as a1 #00D2DD
state "**H**\nVIP validation" as h2 #E7E9EE
state "**A** //Customer Service//\nCustomer file" as a2 #00D2DD
state "**A** //Pricing//\nPricing" as a3 #00D2DD
state "**H**\nFinal approval" as h3 #E7E9EE

state "**A** //Inventory//" as ctx1 #DAF6F9
state "**A** //Weather//" as ctx2 #DAF6F9
state "**A** //CRM//" as ctx3 #DAF6F9
state "**A** //Capacity//" as ctx4 #DAF6F9

h1 -[#0E2356,thickness=2]-> a1
a1 -[#0E2356,thickness=2]-> h2
h2 -[#0E2356,thickness=2]-> a2
a2 -[#00D2DD,thickness=2]-> a3 : A2A
a3 -[#0E2356,thickness=2]-> h3

a1 -[#6E7B9A,dashed]-> ctx1
ctx1 -[#6E7B9A,dashed]-> a1

a1 -[#6E7B9A,dashed]-> ctx2
ctx2 -[#6E7B9A,dashed]-> a1

a2 -[#6E7B9A,dashed]-> ctx3
ctx3 -[#6E7B9A,dashed]-> a2

a3 -[#6E7B9A,dashed]-> ctx4
ctx4 -[#6E7B9A,dashed]-> a3

a1 -[#6E7B9A,dashed]-> ctx4

caption Value emerges from the mesh: agents exchange context to enrich their decisions.

@enduml
