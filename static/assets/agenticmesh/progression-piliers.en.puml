@startuml
!theme plain
skinparam backgroundColor #FFFFFF
skinparam defaultFontName Helvetica
skinparam RoundCorner 14

left to right direction

rectangle "**Foundation**" as f #E7E9EE
rectangle "**Platform**" as p #B7BDCC
rectangle "**Domains**" as d #DAF6F9
rectangle "**Mesh**" as m #00D2DD

f -[#0E2356,thickness=2]right-> p
p -[#0E2356,thickness=2]right-> d
d -[#0E2356,thickness=2]right-> m

@enduml
